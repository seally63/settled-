-- ============================================================================

DO $$
BEGIN
  IF EXISTS (SELECT 1 FROM information_schema.tables WHERE table_name = 'service_types') THEN
    EXECUTE 'ALTER TABLE service_types ENABLE ROW LEVEL SECURITY';

    -- Drop existing policies if they exist
    EXECUTE 'DROP POLICY IF EXISTS "Everyone can view service types" ON service_types';
    EXECUTE 'DROP POLICY IF EXISTS "Service role can modify service_types" ON service_types';

    -- Everyone can read service types (reference data)
    EXECUTE 'CREATE POLICY "Everyone can view service types"
    ON service_types
    FOR SELECT
    TO authenticated, anon
    USING (true)';

    -- Only service role can modify
    EXECUTE 'CREATE POLICY "Service role can modify service_types"
    ON service_types
    FOR ALL
    TO service_role
    USING (true)
    WITH CHECK (true)';
  END IF;
END $$;

