-- ============================================================================
-- Security Migration: Enable RLS and Create Policies
-- Date: 2026-01-22
-- Description: Comprehensive Row Level Security for all sensitive tables
-- ============================================================================

-- ============================================================================
-- HELPER FUNCTIONS
-- ============================================================================

-- Check if user is admin
CREATE OR REPLACE FUNCTION is_admin()
RETURNS BOOLEAN AS $$
BEGIN
  RETURN EXISTS (
    SELECT 1 FROM profiles
    WHERE id = auth.uid()
    AND is_admin = true
  );
END;
$$ LANGUAGE plpgsql SECURITY DEFINER STABLE;

-- Check if user is participant in a quote request conversation
CREATE OR REPLACE FUNCTION is_request_participant(p_request_id UUID)
RETURNS BOOLEAN AS $$
BEGIN
  RETURN EXISTS (
    -- User is the requester (client)
    SELECT 1 FROM quote_requests
    WHERE id = p_request_id AND requester_id = auth.uid()
  ) OR EXISTS (
    -- User is a targeted trade
    SELECT 1 FROM request_targets
    WHERE request_id = p_request_id AND trade_id = auth.uid()
  );
END;
$$ LANGUAGE plpgsql SECURITY DEFINER STABLE;

-- ============================================================================
-- 1. PROFILES TABLE
-- ============================================================================

ALTER TABLE profiles ENABLE ROW LEVEL SECURITY;

-- Drop existing policies if they exist
DROP POLICY IF EXISTS "Users can view own profile" ON profiles;
DROP POLICY IF EXISTS "Users can view trade public info" ON profiles;
DROP POLICY IF EXISTS "Users can update own profile" ON profiles;
DROP POLICY IF EXISTS "Service role full access to profiles" ON profiles;

-- Users can read their own full profile
CREATE POLICY "Users can view own profile"
ON profiles
FOR SELECT
TO authenticated
USING (id = auth.uid());

-- Users can view basic info of other trades (for messaging context, search)
CREATE POLICY "Users can view trade public info"
ON profiles
FOR SELECT
TO authenticated
USING (
  role = 'trades'
  AND id != auth.uid()
);

-- Users can update their own profile (but not role, is_admin, id, created_at)
-- Note: These field restrictions are enforced at the application layer in updateMyProfile()
CREATE POLICY "Users can update own profile"
ON profiles
FOR UPDATE
TO authenticated
USING (id = auth.uid())
WITH CHECK (id = auth.uid());

-- Service role can do everything (for admin operations)
CREATE POLICY "Service role full access to profiles"
ON profiles
FOR ALL
TO service_role
USING (true)
WITH CHECK (true);

-- ============================================================================
-- 2. TRADIFY_NATIVE_APP_DB (QUOTES) TABLE
-- ============================================================================

ALTER TABLE tradify_native_app_db ENABLE ROW LEVEL SECURITY;

-- Drop existing policies if they exist
DROP POLICY IF EXISTS "Trades can view own quotes" ON tradify_native_app_db;
DROP POLICY IF EXISTS "Clients can view quotes for their requests" ON tradify_native_app_db;
DROP POLICY IF EXISTS "Trades can create quotes" ON tradify_native_app_db;
DROP POLICY IF EXISTS "Trades can update own quotes" ON tradify_native_app_db;
DROP POLICY IF EXISTS "Service role full access to quotes" ON tradify_native_app_db;

-- Trades can see their own quotes
CREATE POLICY "Trades can view own quotes"
ON tradify_native_app_db
FOR SELECT
TO authenticated
USING (trade_id = auth.uid());

-- Clients can see quotes for their requests
CREATE POLICY "Clients can view quotes for their requests"
ON tradify_native_app_db
FOR SELECT
TO authenticated
USING (client_id = auth.uid());

-- Trades can insert quotes (must be their own)
CREATE POLICY "Trades can create quotes"
ON tradify_native_app_db
FOR INSERT
TO authenticated
WITH CHECK (trade_id = auth.uid());

-- Trades can update their own quotes
CREATE POLICY "Trades can update own quotes"
ON tradify_native_app_db
FOR UPDATE
TO authenticated
USING (trade_id = auth.uid())
WITH CHECK (trade_id = auth.uid());

-- Service role can do everything
CREATE POLICY "Service role full access to quotes"
ON tradify_native_app_db
FOR ALL
TO service_role
USING (true)
WITH CHECK (true);

-- ============================================================================
-- 3. QUOTE_REQUESTS TABLE
-- ============================================================================

ALTER TABLE quote_requests ENABLE ROW LEVEL SECURITY;

-- Drop existing policies if they exist
DROP POLICY IF EXISTS "Clients can view own requests" ON quote_requests;
DROP POLICY IF EXISTS "Trades can view targeted requests" ON quote_requests;
DROP POLICY IF EXISTS "Clients can create requests" ON quote_requests;
DROP POLICY IF EXISTS "Clients can update own requests" ON quote_requests;
DROP POLICY IF EXISTS "Service role full access to requests" ON quote_requests;

-- Clients can see their own requests
CREATE POLICY "Clients can view own requests"
ON quote_requests
FOR SELECT
TO authenticated
USING (requester_id = auth.uid());

-- Trades can see requests where they are in request_targets
CREATE POLICY "Trades can view targeted requests"
ON quote_requests
FOR SELECT
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM request_targets
    WHERE request_targets.request_id = quote_requests.id
    AND request_targets.trade_id = auth.uid()
  )
);

-- Clients can create requests (must be their own)
CREATE POLICY "Clients can create requests"
ON quote_requests
FOR INSERT
TO authenticated
WITH CHECK (requester_id = auth.uid());

-- Clients can update their own requests
CREATE POLICY "Clients can update own requests"
ON quote_requests
FOR UPDATE
TO authenticated
USING (requester_id = auth.uid())
WITH CHECK (requester_id = auth.uid());

-- Service role can do everything
CREATE POLICY "Service role full access to requests"
ON quote_requests
FOR ALL
TO service_role
USING (true)
WITH CHECK (true);

-- ============================================================================
-- 4. REQUEST_TARGETS TABLE
-- ============================================================================

ALTER TABLE request_targets ENABLE ROW LEVEL SECURITY;

-- Drop existing policies if they exist
DROP POLICY IF EXISTS "Trades can view own targets" ON request_targets;
DROP POLICY IF EXISTS "Clients can view targets for own requests" ON request_targets;
DROP POLICY IF EXISTS "Trades can update own targets" ON request_targets;
DROP POLICY IF EXISTS "Service role full access to targets" ON request_targets;

-- Trades can see their own target records
CREATE POLICY "Trades can view own targets"
ON request_targets
FOR SELECT
TO authenticated
USING (trade_id = auth.uid());

-- Clients can see targets for their own requests
CREATE POLICY "Clients can view targets for own requests"
ON request_targets
FOR SELECT
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM quote_requests
    WHERE quote_requests.id = request_targets.request_id
    AND quote_requests.requester_id = auth.uid()
  )
);

-- Trades can update their own target records (e.g., accept/decline)
CREATE POLICY "Trades can update own targets"
ON request_targets
FOR UPDATE
TO authenticated
USING (trade_id = auth.uid())
WITH CHECK (trade_id = auth.uid());

-- Service role can do everything (system creates targets)
CREATE POLICY "Service role full access to targets"
ON request_targets
FOR ALL
TO service_role
USING (true)
WITH CHECK (true);

-- ============================================================================
-- 5. MESSAGES TABLE
-- ============================================================================

ALTER TABLE messages ENABLE ROW LEVEL SECURITY;

-- Drop existing policies if they exist
DROP POLICY IF EXISTS "Users can view messages in their conversations" ON messages;
DROP POLICY IF EXISTS "Users can send messages in their conversations" ON messages;
DROP POLICY IF EXISTS "Service role full access to messages" ON messages;

-- Users can see messages where they are a participant in the conversation
CREATE POLICY "Users can view messages in their conversations"
ON messages
FOR SELECT
TO authenticated
USING (
  sender_id = auth.uid()
  OR is_request_participant(request_id)
);

-- Users can send messages where they are the sender and a participant
CREATE POLICY "Users can send messages in their conversations"
ON messages
FOR INSERT
TO authenticated
WITH CHECK (
  sender_id = auth.uid()
  AND is_request_participant(request_id)
);

-- Service role can do everything
CREATE POLICY "Service role full access to messages"
ON messages
FOR ALL
TO service_role
USING (true)
WITH CHECK (true);

-- ============================================================================
-- 6. REVIEWS TABLE
-- ============================================================================

ALTER TABLE reviews ENABLE ROW LEVEL SECURITY;

-- Drop existing policies if they exist
DROP POLICY IF EXISTS "Authenticated users can view all reviews" ON reviews;
DROP POLICY IF EXISTS "Users can create their own reviews" ON reviews;
DROP POLICY IF EXISTS "Users can update own reviews" ON reviews;
DROP POLICY IF EXISTS "Service role full access to reviews" ON reviews;

-- Anyone authenticated can read reviews (public)
CREATE POLICY "Authenticated users can view all reviews"
ON reviews
FOR SELECT
TO authenticated
USING (true);

-- Users can insert reviews where they are the reviewer
CREATE POLICY "Users can create their own reviews"
ON reviews
FOR INSERT
TO authenticated
WITH CHECK (reviewer_id = auth.uid());

-- Users can update their own reviews
CREATE POLICY "Users can update own reviews"
ON reviews
FOR UPDATE
TO authenticated
USING (reviewer_id = auth.uid())
WITH CHECK (reviewer_id = auth.uid());

-- Service role can do everything
CREATE POLICY "Service role full access to reviews"
ON reviews
FOR ALL
TO service_role
USING (true)
WITH CHECK (true);

-- ============================================================================
-- 7. APPOINTMENTS TABLE
-- ============================================================================
-- Note: Appointments are linked through request_id and quote_id, not direct trade_id
-- Access is controlled via relationships to quote_requests and tradify_native_app_db (quotes)

ALTER TABLE appointments ENABLE ROW LEVEL SECURITY;

-- Drop existing policies if they exist
DROP POLICY IF EXISTS "Trades can view own appointments" ON appointments;
DROP POLICY IF EXISTS "Clients can view appointments for their requests" ON appointments;
DROP POLICY IF EXISTS "Trades can create appointments" ON appointments;
DROP POLICY IF EXISTS "Trades can update own appointments" ON appointments;
DROP POLICY IF EXISTS "Clients can update appointment status" ON appointments;
DROP POLICY IF EXISTS "Service role full access to appointments" ON appointments;
DROP POLICY IF EXISTS "Users can view related appointments" ON appointments;
DROP POLICY IF EXISTS "Authenticated can view appointments via relationships" ON appointments;

-- Users can view appointments for requests/quotes they are involved in
-- Trades: via quote they own OR request_target they're in
-- Clients: via quote_request they own
CREATE POLICY "Authenticated can view appointments via relationships"
ON appointments
FOR SELECT
TO authenticated
USING (
  -- Client owns the quote request
  EXISTS (
    SELECT 1 FROM quote_requests
    WHERE quote_requests.id = appointments.request_id
    AND quote_requests.requester_id = auth.uid()
  )
  OR
  -- Trade owns the quote
  EXISTS (
    SELECT 1 FROM tradify_native_app_db
    WHERE tradify_native_app_db.id = appointments.quote_id
    AND tradify_native_app_db.trade_id = auth.uid()
  )
  OR
  -- Trade is targeted on the request
  EXISTS (
    SELECT 1 FROM request_targets
    WHERE request_targets.request_id = appointments.request_id
    AND request_targets.trade_id = auth.uid()
  )
);

-- Service role can do everything (RPC functions handle creation/updates)
CREATE POLICY "Service role full access to appointments"
ON appointments
FOR ALL
TO service_role
USING (true)
WITH CHECK (true);

-- ============================================================================
-- 8. PHOTO_ID_SUBMISSIONS TABLE (SENSITIVE)
-- ============================================================================
-- Note: Table may not exist yet, or may have different column names.
-- Check for both table AND column existence before creating policies.

DO $$
BEGIN
  IF EXISTS (
    SELECT 1 FROM information_schema.columns
    WHERE table_name = 'photo_id_submissions' AND column_name = 'profile_id'
  ) THEN
    EXECUTE 'ALTER TABLE photo_id_submissions ENABLE ROW LEVEL SECURITY';

    -- Drop existing policies if they exist
    EXECUTE 'DROP POLICY IF EXISTS "Trades can view own photo_id submissions" ON photo_id_submissions';
    EXECUTE 'DROP POLICY IF EXISTS "Trades can create photo_id submissions" ON photo_id_submissions';
    EXECUTE 'DROP POLICY IF EXISTS "Admins can view all photo_id submissions" ON photo_id_submissions';
    EXECUTE 'DROP POLICY IF EXISTS "Admins can update photo_id submissions" ON photo_id_submissions';
    EXECUTE 'DROP POLICY IF EXISTS "Service role full access to photo_id_submissions" ON photo_id_submissions';

    EXECUTE 'CREATE POLICY "Trades can view own photo_id submissions"
    ON photo_id_submissions
    FOR SELECT
    TO authenticated
    USING (profile_id = auth.uid())';

    EXECUTE 'CREATE POLICY "Trades can create photo_id submissions"
    ON photo_id_submissions
    FOR INSERT
    TO authenticated
    WITH CHECK (profile_id = auth.uid())';

    EXECUTE 'CREATE POLICY "Admins can view all photo_id submissions"
    ON photo_id_submissions
    FOR SELECT
    TO authenticated
    USING (is_admin())';

    EXECUTE 'CREATE POLICY "Admins can update photo_id submissions"
    ON photo_id_submissions
    FOR UPDATE
    TO authenticated
    USING (is_admin())
    WITH CHECK (is_admin())';

    EXECUTE 'CREATE POLICY "Service role full access to photo_id_submissions"
    ON photo_id_submissions
    FOR ALL
    TO service_role
    USING (true)
    WITH CHECK (true)';
  END IF;
END $$;

