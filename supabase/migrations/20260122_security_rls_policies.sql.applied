-- ============================================================================
-- 12. TRADE_VERIFICATIONS TABLE
-- ============================================================================

DO $$
DECLARE
  v_user_column TEXT;
BEGIN
  IF EXISTS (SELECT 1 FROM information_schema.tables WHERE table_name = 'trade_verifications') THEN
    -- Determine which column to use for user identification (profile_id or user_id)
    SELECT column_name INTO v_user_column
    FROM information_schema.columns
    WHERE table_name = 'trade_verifications'
      AND column_name IN ('profile_id', 'user_id')
    LIMIT 1;

    -- If no user column found, skip RLS setup
    IF v_user_column IS NULL THEN
      RAISE NOTICE 'trade_verifications table has no profile_id or user_id column, skipping RLS';
      RETURN;
    END IF;

    EXECUTE 'ALTER TABLE trade_verifications ENABLE ROW LEVEL SECURITY';

    -- Drop existing policies if they exist
    EXECUTE 'DROP POLICY IF EXISTS "Trades can view own verifications" ON trade_verifications';
    EXECUTE 'DROP POLICY IF EXISTS "Admins can view all verifications" ON trade_verifications';
    EXECUTE 'DROP POLICY IF EXISTS "Admins can update verifications" ON trade_verifications';
    EXECUTE 'DROP POLICY IF EXISTS "Service role full access to trade_verifications" ON trade_verifications';

    EXECUTE format('CREATE POLICY "Trades can view own verifications"
    ON trade_verifications
    FOR SELECT
    TO authenticated
    USING (%I = auth.uid())', v_user_column);

    EXECUTE 'CREATE POLICY "Admins can view all verifications"
    ON trade_verifications
    FOR SELECT
    TO authenticated
    USING (is_admin())';

    EXECUTE 'CREATE POLICY "Admins can update verifications"
    ON trade_verifications
    FOR ALL
    TO authenticated
    USING (is_admin())
    WITH CHECK (is_admin())';

    EXECUTE 'CREATE POLICY "Service role full access to trade_verifications"
    ON trade_verifications
    FOR ALL
    TO service_role
    USING (true)
    WITH CHECK (true)';
  END IF;
END $$;

